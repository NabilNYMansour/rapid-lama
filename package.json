{
  "name": "rlama",
  "version": "1.0.0",
  "description": "A TypeScript CLI tool",
  "main": "dist/cli.js",
  "bin": {
    "rlama": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "node ./dist/cli.js",
    "publish": "(npm whoami >/dev/null 2>&1 || npm login) && pnpm build && pnpm version patch && npm publish"
  },
  "keywords": ["rapid ollama", "quick response", "ai cli tool", "ai assistant", "command line tool", "cli"],
  "author": "Nabil Mansour",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
